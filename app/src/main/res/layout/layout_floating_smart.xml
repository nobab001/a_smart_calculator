<?xml version="1.0" encoding="utf-8"?>
<!--
    Smart Mode Floating Window ~200 × 220dp
    Top bar : [History icon] [drag title] [−] [×]
    Display : Running total (large)
    Action  : Copy / Share / Clear button
    History : Expandable panel (hidden by default)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/smartRoot"
    android:layout_width="210dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_float_window"
    android:clipToOutline="true">

    <!-- ── Title bar (drag handle) ── -->
    <LinearLayout
        android:id="@+id/smartHeader"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/bg_float_header">

        <ImageButton
            android:id="@+id/btnSmartHistory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_history"
            android:background="@drawable/bg_icon_btn"
            android:contentDescription="History"
            android:padding="7dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Smart Calc"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"/>

        <ImageButton
            android:id="@+id/btnSmartMinimize"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_minimize"
            android:background="@drawable/bg_icon_btn"
            android:contentDescription="Minimize"
            android:padding="7dp"/>

        <Space android:layout_width="4dp" android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/btnSmartClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_icon_btn"
            android:contentDescription="Close"
            android:clickable="true"
            android:focusable="true"
            android:padding="7dp"/>
    </LinearLayout>

    <!-- ── Expression + Total display ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- Expression row: "100 + 250 + 30" scrollable horizontally -->
        <HorizontalScrollView
            android:id="@+id/scrollSmartExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvSmartExpression"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/btn_operator"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:singleLine="true"
                android:paddingHorizontal="2dp"/>
        </HorizontalScrollView>

        <!-- TOTAL label -->
        <TextView
            android:id="@+id/tvSmartLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TOTAL"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:gravity="center"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"/>

        <!-- Large total number -->
        <TextView
            android:id="@+id/tvSmartTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/text_primary"
            android:textSize="40sp"
            android:gravity="center"
            android:singleLine="true"
            android:ellipsize="start"
            android:fontFamily="sans-serif-light"
            android:includeFontPadding="false"/>

        <!-- Item count: "3 selections" -->
        <TextView
            android:id="@+id/tvSmartCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ── Action buttons row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <!-- Undo Last Selection -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSmartUndo"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="↩ Undo"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/btn_function"
            app:cornerRadius="12dp"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <!-- Copy Result -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSmartAction"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Copy"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/btn_action"
            app:cornerRadius="12dp"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

    </LinearLayout>

    <!-- ── History Panel (hidden by default) ── -->
    <LinearLayout
        android:id="@+id/layoutHistoryPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- History divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HISTORY"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:gravity="center"
            android:paddingTop="8dp"
            android:fontFamily="sans-serif-medium"/>

        <!-- History entries - dynamically populated -->
        <LinearLayout
            android:id="@+id/layoutHistoryItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"/>

        <!-- Divider before total -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="4dp"
            android:background="@color/btn_operator"/>

        <TextView
            android:id="@+id/tvHistoryTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total: 0"
            android:textColor="@color/btn_operator"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="end"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- Clear session button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearHistory"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="10dp"
            android:text="Clear Session"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/btn_function"
            app:cornerRadius="10dp"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

    </LinearLayout>

</LinearLayout>
