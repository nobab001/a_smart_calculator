<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SmartCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/btn_operator</item>
        <item name="colorPrimaryVariant">@color/btn_operator_pressed</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/btn_equals</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <style name="CalcButtonBase" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_margin">7dp</item>
        <item name="android:textSize">23sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="CalcButtonNumber" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_number</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="CalcButtonFunction" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_function</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">19sp</item>
    </style>

    <style name="CalcButtonOperator" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_operator</item>
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="CalcButtonEquals" parent="CalcButtonBase">
        <item name="backgroundTint">@color/btn_equals</item>
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">27sp</item>
    </style>

</resources>
